<%# Work-type choice buttons. Rendered inside a form supplied by the caller;
    each button submits its own work_type value. Shows an empty-state message
    when the tenant has no available work types. %>
<% if available_work_types.any? %>
  <div class="deposit-wizard__type-cards">
    <% available_work_types.each do |model| %>
      <%= button_tag type: 'submit', name: 'work_type', value: model.to_s,
                     class: "deposit-wizard__type-card btn btn-outline-primary#{' active' if wizard_state.work_type == model.to_s}" do %>
        <span class="deposit-wizard__type-card-label"><%= model.model_name.human %></span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p class="deposit-wizard__empty alert alert-warning"><%= t('hyku.deposit_wizard.no_work_types') %></p>
<% end %>
