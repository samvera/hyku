<%# The deposit-agreement consent, shown when the installation requires it.
    Active mode needs an explicit checked box (enforced in #commit); passive mode
    is informational. %>
<% if Flipflop.show_deposit_agreement? %>
  <div class="deposit-wizard__agreement">
    <% if Flipflop.active_deposit_agreement_acceptance? %>
      <label>
        <%= check_box_tag 'agreement', '1', false, required: true %>
        <%= t('hyrax.active_consent_to_agreement') %>
        <%= link_to t('hyrax.pages.tabs.agreement_page'), hyrax.agreement_path, target: '_blank', rel: 'noopener' %>
      </label>
    <% else %>
      <%= t('hyrax.passive_consent_to_agreement') %>
      <%= link_to t('hyrax.pages.tabs.agreement_page'), hyrax.agreement_path, target: '_blank', rel: 'noopener' %>
    <% end %>
  </div>
<% end %>
