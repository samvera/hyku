<% content_for :page_header do %>
  <h1><span class="fa fa-edit"></span> <%= t('hyku.admin.stats.header', application_name: application_name) %></h1>
<% end %>

<div class="card tabs">
  <!-- Nav tabs -->
  <ul id="statistics-tabs" class="nav nav-tabs" role="tablist">
    <li class="nav-item" role="presentation">
      <a class="nav-link active" href="#collections" role="tab" data-toggle="tab"><%= t('hyku.admin.stats.tab_collections') %></a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="#works" role="tab" data-toggle="tab"><%= t('hyku.admin.stats.tab_works') %></a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="#downloads" role="tab" data-toggle="tab"><%= t('hyku.admin.stats.downloads') %></a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="#users" role="tab" data-toggle="tab"><%= t('hyku.admin.stats.users') %></a>
    </li>
  </ul>

  <!-- Tab panes -->
  <div class="tab-content">
    <div class="tab-pane active" id="collections">
      <div class="card labels">
        <div class="card-body">
          <h2><%= t('hyku.admin.stats.collections_over_time') %></h2>
          <%=
          graph_tag('collection-graph', [Hyrax::Statistics::Collections::OverTime.new.points], {
            xaxis: {
              mode: 'time',
              minTickSize: [7, 'day']
            },
            yaxis: {
              minTickSize: 1,
              tickDecimals: 0,
              min: 0
            }
          })
          %>
        </div>
      </div>
    </div>
    <div role="tabpanel" class="tab-pane" id="works">
      <div class="card labels">
        <div class="card-body">
          <h2><%= t('hyku.admin.stats.works_over_time') %></h2>
          <%=
          graph_tag('works-graph', [Hyrax::Statistics::Works::OverTime.new.points], {
            xaxis: {
              mode: 'time',
              minTickSize: [7, 'day']
            },
            yaxis: {
              minTickSize: 1,
              tickDecimals: 0,
              min: 0
            }
          })
          %>
          <h2><%= t('hyku.admin.stats.works_by_type') %></h2>
          <%=
          graph_tag('works-by-type', Hyrax::Statistics::Works::ByResourceType.new.query, series: {
            pie: {
              show: true,
            }
          })
          %>
        </div>
      </div>
    </div>
    <div role="tabpanel" class="tab-pane" id="downloads">
      <div class="card labels">
        <div class="card-body">
          ...
        </div>
      </div>
    </div>
    <div role="tabpanel" class="tab-pane" id="users">
      <div class="card labels">
        <div class="card-body">
          <%= render "hyrax/admin/stats/stats_by_date" %>
          <%= render "hyrax/admin/stats/top_data" %>
        </div>
      </div>
    </div>
    <script>
     Blacklight.onLoad(function() {
       var stats = require('statistics_tab_manager');
       new stats.Tab('#collections').show();
       new stats.Tab('#works');
     });
    </script>
  </div>
</div>
