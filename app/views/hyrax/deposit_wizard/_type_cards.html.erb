<%# Work-type cards. Each is a label wrapping a hidden radio named work_type;
    selecting one marks the card (JS adds .is-selected) and enables the caller's
    Next button. The caller supplies the form and the Next submit. %>
<% if deposit_wizard.available_work_types.any? %>
  <div class="deposit-wizard__type-cards" data-behavior="type-select">
    <% deposit_wizard.available_work_types.each do |model| %>
      <% presenter = Hyrax::SelectTypePresenter.new(model) %>
      <% selected = deposit_wizard.state.work_type == model.to_s %>
      <label class="deposit-wizard__type-card<%= ' is-selected' if selected %>">
        <%= radio_button_tag 'work_type', model.to_s, selected, class: 'deposit-wizard__type-radio sr-only', data: { behavior: 'type-option' } %>
        <span class="deposit-wizard__type-card-icon <%= presenter.icon_class %>" aria-hidden="true"></span>
        <span class="deposit-wizard__type-card-label"><%= model.model_name.human %></span>
        <% if presenter.description.present? %>
          <span class="deposit-wizard__type-card-desc"><%= presenter.description %></span>
        <% end %>
      </label>
    <% end %>
  </div>
<% else %>
  <p class="deposit-wizard__empty alert alert-warning"><%= t('hyku.deposit_wizard.no_work_types') %></p>
<% end %>
